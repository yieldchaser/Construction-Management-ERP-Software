{
  "title": "Steps to Set Up a Project Estimate and BOQ in SiteFlow",
  "metaTitle": "Steps to Set Up a Project Estimate and BOQ in SiteFlow",
  "metaDescription": "Create a project estimate and BOQ in SiteFlow — add line items with labour, material, and fee costs, apply markup, set milestones, and generate sales invoices against the BOQ.",
  "canonical": "https://siteflow.com/help/budgeting-cost-control/how-to-create-and-manage-project-estimates-and-invoices/",
