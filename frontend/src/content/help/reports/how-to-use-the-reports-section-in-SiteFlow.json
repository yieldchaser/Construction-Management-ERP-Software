{
  "title": "Overview of All Reports in SiteFlow — Full Guide",
  "metaTitle": "Overview of All Reports in SiteFlow — Full Guide",
  "metaDescription": "All 16 report categories in SiteFlow explained — Sales, Payments, Materials, Attendance, Tax, BOQ, Budget, and more. Covers how to open, filter, and download each report.",
  "canonical": "https://siteflow.com/help/reports/how-to-use-the-reports-section-in-SiteFlow/",
  "slug": "reports/how-to-use-the-reports-section-in-SiteFlow",
  "category": "reports",
