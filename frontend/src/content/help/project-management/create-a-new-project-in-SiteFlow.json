  "title": "Steps to Set Up a New Project in SiteFlow",
  "metaTitle": "Steps to Set Up a New Project in SiteFlow",
  "metaDescription": "Create a new project in SiteFlow step by step — enter project details, add team members, set an attendance radius geofence, configure location structure for inspections, and finish setup.",
  "canonical": "https://siteflow.com/help/project-management/create-a-new-project-in-SiteFlow/",
