{
  "title": "Managing Project Settings and Approvals in SiteFlow",
  "metaTitle": "Managing Project Settings and Approvals in SiteFlow",
  "metaDescription": "Change project status, review pending approvals, edit project details including geo location and project value, manage location structure for inspections, and update profile settings in SiteFlow.",
  "canonical": "https://siteflow.com/help/project-management/manage-project-settings-and-approvals-in-SiteFlow/",
  "slug": "project-management/manage-project-settings-and-approvals-in-SiteFlow",
