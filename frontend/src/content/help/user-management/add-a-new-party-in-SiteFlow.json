{
  "title": "Steps to Include a New Party in SiteFlow",
  "metaTitle": "Steps to Include a New Party in SiteFlow",
  "metaDescription": "Add a new party in SiteFlow by selecting the party type, filling in contact and compliance fields, adding GST addresses, and saving bank account details. Parties are available across all projects immediately.",
  "canonical": "https://siteflow.com/help/user-management/add-a-new-party-in-SiteFlow/",
  "slug": "user-management/add-a-new-party-in-SiteFlow",
