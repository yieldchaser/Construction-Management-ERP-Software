{
  "title": "Steps to Configure Finance Settings in SiteFlow",
  "metaTitle": "Steps to Configure Finance Settings in SiteFlow",
  "metaDescription": "Step-by-step guide to setting up finance settings in SiteFlow — pre-tax deduction, retention, invoice numbering, invoice prefix, and cost codes for all projects.",
  "canonical": "https://siteflow.com/help/settings-configuration/how-to-configure-finance-settings/",
