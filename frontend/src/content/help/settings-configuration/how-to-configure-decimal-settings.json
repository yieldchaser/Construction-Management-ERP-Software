{
  "title": "Steps to Configure Decimal Settings in SiteFlow",
  "metaTitle": "Steps to Configure Decimal Settings in SiteFlow",
  "metaDescription": "Set currency and quantity decimal places in SiteFlow. Control how amounts display on invoices, purchase orders, BOQs, GRNs, and reports across all projects.",
  "canonical": "https://siteflow.com/help/settings-configuration/how-to-configure-decimal-settings/",
  "slug": "settings-configuration/how-to-configure-decimal-settings",
  "category": "settings-configuration",
