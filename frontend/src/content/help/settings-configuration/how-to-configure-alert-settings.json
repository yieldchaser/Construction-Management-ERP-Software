{
  "title": "Steps to Configure Alert Settings in SiteFlow",
  "metaTitle": "Steps to Configure Alert Settings in SiteFlow",
  "metaDescription": "Set up WhatsApp alert settings in SiteFlow — enable alerts for material requests, GRN, task progress, punch in/out, material shortage, and sales invoices by role.",
  "canonical": "https://siteflow.com/help/settings-configuration/how-to-configure-alert-settings/",
  "slug": "settings-configuration/how-to-configure-alert-settings",
  "category": "settings-configuration",
