{
  "title": "Steps to Configure Material Settings in SiteFlow",
  "metaTitle": "Steps to Configure Material Settings in SiteFlow",
  "metaDescription": "Step-by-step guide to configuring material settings in SiteFlow — negative stock restrictions, MR and PO controls, BOM restrictions, RFQ limits, and GRN and MR document numbering.",
  "canonical": "https://siteflow.com/help/settings-configuration/how-to-configure-material-settings/",
  "slug": "settings-configuration/how-to-configure-material-settings",
  "category": "settings-configuration",
