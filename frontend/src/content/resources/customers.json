  "body": "\n\n<div class=\"oscs2-outer\">\n<div class=\"oscs2-top-bar\"></div>\n<div class=\"oscs2-inner\">\n<div class=\"oscs2-eyebrow\"><div class=\"oscs2-ey-dot\"></div>Customer Success Stories</div>\n<h1 class=\"oscs2-h1\">Real outcomes from construction companies <span class=\"oscs2-h1-accent\">using SiteFlow.</span></h1>\n<p class=\"oscs2-sub\">From residential builders to EPC firms. Trusted across India, the Middle East, Africa, and beyond.</p>\n<div class=\"oscs2-metrics\">\n<div class=\"oscs2-metric\">\n<div class=\"oscs2-metric-num\">10,000<span>+</span></div>\n<div class=\"oscs2-metric-lbl\">Active clients</div>\n</div>\n<div class=\"oscs2-metric\">\n<div class=\"oscs2-metric-num\"><span>Global</span></div>\n<div class=\"oscs2-metric-lbl\">India, Middle East &amp; beyond</div>\n</div>\n<div class=\"oscs2-metric\">\n<div class=\"oscs2-metric-num\">5<span>+</span></div>\n<div class=\"oscs2-metric-lbl\">Construction verticals</div>\n</div>\n</div>\n<div class=\"oscs2-cta-row\">\n<a class=\"oscs2-btn-primary\" href=\"#ct-popup-48098\">\n        Book a free demo\n        <svg aria-hidden=\"true\" fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#fff\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg>\n</a>\n<a class=\"oscs2-btn-ghost\" href=\"#case-studies\">Browse all stories</a>\n</div>\n</div>\n</div>\n\n<div class=\"oscg-outer\" id=\"case-studies\">\n<div class=\"oscg-inner\">\n<div class=\"oscg-head\">\n<div>\n<div class=\"oscg-eyebrow\"><div class=\"oscg-ey-dot\"></div>All case studies</div>\n<h2 class=\"oscg-h2\">Stories from the field</h2>\n</div>\n<div class=\"oscg-count\" id=\"oscg-count\">Showing 14 of 14</div>\n</div>\n<div class=\"oscg-filters\" role=\"tablist\">\n<div class=\"oscg-pill oscg-active\" data-filter=\"all\" role=\"tab\">All</div>\n<div class=\"oscg-pill\" data-filter=\"india\" role=\"tab\">India</div>\n<div class=\"oscg-pill\" data-filter=\"middle-east\" role=\"tab\">Middle East</div>\n<div class=\"oscg-pill\" data-filter=\"labour\" role=\"tab\">Labour &amp; Payroll</div>\n<div class=\"oscg-pill\" data-filter=\"visibility\" role=\"tab\">Project Visibility</div>\n<div class=\"oscg-pill\" data-filter=\"residential\" role=\"tab\">Residential</div>\n<div class=\"oscg-pill\" data-filter=\"industrial\" role=\"tab\">Industrial</div>\n</div>\n<div class=\"oscg-grid\" id=\"oscg-grid\">\n HARDCODED CARD 1 \n<div class=\"oscg-card\" data-tags=\"india residential visibility\">\n<div class=\"oscg-card-bar oscg-bar-violet\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">Reidius Infra</div><div class=\"oscg-co-loc\">📍 Jaipur, India</div></div>\n<p class=\"oscg-outcome\"><strong>Scaled 250+ home projects</strong> from WhatsApp and Excel to a fully visible, real-time operation with zero client escalations.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Residential</span><span class=\"oscg-tag\">Progress Tracking</span><span class=\"oscg-tag oscg-tag-market\">India</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/customers/case-study-reidius-infra/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 2 \n<div class=\"oscg-card\" data-tags=\"india labour\">\n<div class=\"oscg-card-bar oscg-bar-green\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">SFC Infratech</div><div class=\"oscg-co-loc\">📍 North India</div></div>\n<p class=\"oscg-outcome\"><strong>Eliminated payroll errors</strong> and gained real-time labour visibility across 50–100 workers on multiple sites.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Infrastructure</span><span class=\"oscg-tag\">Labour &amp; Payroll</span><span class=\"oscg-tag oscg-tag-market\">India</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/customers/sfc-infratech/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 3 \n<div class=\"oscg-card\" data-tags=\"india visibility\">\n<div class=\"oscg-card-bar oscg-bar-blue\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">Theeran Avant</div><div class=\"oscg-co-loc\">📍 Erode, India</div></div>\n<p class=\"oscg-outcome\"><strong>Replaced verbal instructions</strong> with real-time task tracking — bottlenecks visible same day, accountability restored.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Mechanical Works</span><span class=\"oscg-tag\">Task Visibility</span><span class=\"oscg-tag oscg-tag-market\">India</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/customers/theeran-avant/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 4 \n<div class=\"oscg-card\" data-tags=\"middle-east visibility\">\n<div class=\"oscg-card-bar oscg-bar-teal\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">Hydro Flow Qatar Pools</div><div class=\"oscg-co-loc\">📍 Qatar</div></div>\n<p class=\"oscg-outcome\"><strong>Closed the client communication gap</strong> on luxury pool projects — real-time updates replacing scattered WhatsApp reports.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Luxury Construction</span><span class=\"oscg-tag\">Client Reporting</span><span class=\"oscg-tag oscg-tag-market\">Middle East</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/customers/hydro-master/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 5 \n<div class=\"oscg-card\" data-tags=\"middle-east visibility\">\n<div class=\"oscg-card-bar oscg-bar-amber\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">Cyath Contracting</div><div class=\"oscg-co-loc\">📍 Dubai, UAE</div></div>\n<p class=\"oscg-outcome\"><strong>Unified site, documentation and billing</strong> across villa and fit-out projects — one platform replacing multiple disconnected tools.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Villa &amp; Fit-out</span><span class=\"oscg-tag\">Project Management</span><span class=\"oscg-tag oscg-tag-market\">Middle East</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/customers/case-study-cyath-contracting/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 6 \n<div class=\"oscg-card\" data-tags=\"middle-east labour\">\n<div class=\"oscg-card-bar oscg-bar-rose\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">M. Munif Al Otaibi</div><div class=\"oscg-co-loc\">📍 Saudi Arabia</div></div>\n<p class=\"oscg-outcome\"><strong>Automated payroll and attendance</strong> on interior fit-out projects — manual tracking errors eliminated completely.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Interior Fit-out</span><span class=\"oscg-tag\">Labour &amp; Payroll</span><span class=\"oscg-tag oscg-tag-market\">Middle East</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/customers/case-study-m-munif-al-otaibi-contracting-est/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 7 \n<div class=\"oscg-card\" data-tags=\"india industrial visibility\">\n<div class=\"oscg-card-bar oscg-bar-indigo\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">Shivam Developers</div><div class=\"oscg-co-loc\">📍 Pune, Maharashtra</div></div>\n<p class=\"oscg-outcome\"><strong>Cut material cost overrun from 12% to 2%</strong> and reduced weekly admin time by 75% — real-time tracking replacing paper logs across industrial shed projects.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Industrial Construction</span><span class=\"oscg-tag\">Material Management</span><span class=\"oscg-tag oscg-tag-market\">India</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/resources/customers/shivam-developers-case-study/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 8 \n<div class=\"oscg-card\" data-tags=\"india industrial visibility labour\">\n<div class=\"oscg-card-bar oscg-bar-violet\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">TCC Projects</div><div class=\"oscg-co-loc\">📍 Ahmedabad, Gujarat</div></div>\n<p class=\"oscg-outcome\"><strong>Ten morning phone calls replaced by one screen</strong> across every active site — budget visibility before every PO, payroll from verified attendance.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Industrial Construction</span><span class=\"oscg-tag\">Procurement &amp; Payroll</span><span class=\"oscg-tag oscg-tag-market\">India</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/resources/customers/tcc-projects/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 9 \n<div class=\"oscg-card\" data-tags=\"visibility labour\">\n<div class=\"oscg-card-bar oscg-bar-green\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">Blueline Urban Projects</div><div class=\"oscg-co-loc\">📍 Lagos, Nigeria</div></div>\n<p class=\"oscg-outcome\"><strong>Live site picture across manpower, materials, and equipment</strong> — consolidated visibility replacing days-behind reporting across all active building projects.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Building Construction</span><span class=\"oscg-tag\">Portfolio Visibility</span><span class=\"oscg-tag oscg-tag-market\">Africa</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/resources/customers/blueline-projects/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 10 \n<div class=\"oscg-card\" data-tags=\"india visibility\">\n<div class=\"oscg-card-bar oscg-bar-blue\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">Srinivasa Earth Movers</div><div class=\"oscg-co-loc\">📍 Bangalore, Karnataka</div></div>\n<p class=\"oscg-outcome\"><strong>Billing backed by deployment records</strong> clients can verify — phone-call tracking replaced by complete equipment history for every project.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Excavation Services</span><span class=\"oscg-tag\">Equipment Tracking</span><span class=\"oscg-tag oscg-tag-market\">India</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/resources/customers/srinivasa-earth-movers/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 11 \n<div class=\"oscg-card\" data-tags=\"india visibility\">\n<div class=\"oscg-card-bar oscg-bar-amber\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">Woodofa Lifestyle</div><div class=\"oscg-co-loc\">📍 Delhi</div></div>\n<p class=\"oscg-outcome\"><strong>Coordination moved from WhatsApp into the project record</strong> — designers, procurement, and site teams all working from the same source of truth.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Interior Design</span><span class=\"oscg-tag\">Design Coordination</span><span class=\"oscg-tag oscg-tag-market\">India</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/resources/customers/woodofa-lifestyle/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 12 \n<div class=\"oscg-card\" data-tags=\"india residential\">\n<div class=\"oscg-card-bar oscg-bar-teal\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">Cfolios Design &amp; Construction</div><div class=\"oscg-co-loc\">📍 Vijayapura, Karnataka</div></div>\n<p class=\"oscg-outcome\"><strong>Approximate bill approvals replaced by verified progress checks</strong> — every subcontractor on a digital work order, every bill matched to recorded completion.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Home Construction</span><span class=\"oscg-tag\">Subcontractor Management</span><span class=\"oscg-tag oscg-tag-market\">India</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/resources/customers/cfolios-design/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 13 \n<div class=\"oscg-card\" data-tags=\"india residential visibility\">\n<div class=\"oscg-card-bar oscg-bar-rose\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">ABI Builders</div><div class=\"oscg-co-loc\">📍 Thoothukudi, Tamil Nadu</div></div>\n<p class=\"oscg-outcome\"><strong>Every housing project visible from one screen</strong> — individual site-by-site calls replaced by a consolidated portfolio view.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Housing Construction</span><span class=\"oscg-tag\">Portfolio Visibility</span><span class=\"oscg-tag oscg-tag-market\">India</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/resources/customers/abi-builders/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n HARDCODED CARD 14 \n<div class=\"oscg-card\" data-tags=\"india visibility\">\n<div class=\"oscg-card-bar oscg-bar-indigo\"></div>\n<div class=\"oscg-card-body\">\n<div><div class=\"oscg-co-name\">Gobito Construction</div><div class=\"oscg-co-loc\">📍 Gurugram, Haryana</div></div>\n<p class=\"oscg-outcome\"><strong>All operational data in the pocket</strong> — sit-down Excel dashboard meetings replaced by on-demand project visibility from mobile.</p>\n<div class=\"oscg-tags\"><span class=\"oscg-tag\">Road Infrastructure</span><span class=\"oscg-tag\">Mobile Access</span><span class=\"oscg-tag oscg-tag-market\">India</span></div>\n</div>\n<div class=\"oscg-card-foot\"><a class=\"oscg-read\" href=\"https://siteflow.com/resources/customers/gobito-construction/\">Read story <svg fill=\"none\" height=\"13\" viewbox=\"0 0 14 14\" width=\"13\"><path d=\"M2.5 7h9M7.5 3.5l4 3.5-4 3.5\" stroke=\"#d30d50\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.6\"></path></svg></a></div>\n</div>\n Auto-fetched cards injected here \n</div>\n</div>\n</div>\n\n\n<div class=\"osts-outer\">\n<div class=\"osts-inner\">\n<div class=\"osts-headline\">\n<div class=\"osts-eyebrow\">Proven at scale</div>\n<h2 class=\"osts-h2\">Numbers from the ground — not the pitch deck</h2>\n<p class=\"osts-sub\">Outcomes aggregated from real SiteFlow deployments across India and the Middle East.</p>\n</div>\n<div class=\"osts-stats\">\n<div class=\"osts-stat\"><div class=\"osts-stat-num\">10,000<sup>+</sup></div><div class=\"osts-stat-lbl\">Active construction teams</div></div>\n<div class=\"osts-stat\"><div class=\"osts-stat-num\">2</div><div class=\"osts-stat-lbl\">Markets — India &amp; Middle East</div></div>\n<div class=\"osts-stat\"><div class=\"osts-stat-num\">10K<sup>+</sup></div><div class=\"osts-stat-lbl\">Workers tracked daily</div></div>\n<div class=\"osts-stat\"><div class=\"osts-stat-num\">5<sup>+</sup></div><div class=\"osts-stat-lbl\">Construction verticals</div></div>\n</div>\n<div class=\"osts-divider\">\n<div class=\"osts-divider-line\"></div>\n<div class=\"osts-divider-text\">Companies that chose SiteFlow</div>\n<div class=\"osts-divider-line\"></div>\n</div>\n<div class=\"osts-clients\">\n<div class=\"osts-client\">Reidius Infra</div>\n<div class=\"osts-client\">SFC Infratech</div>\n<div class=\"osts-client\">Theeran Avant</div>\n<div class=\"osts-client\">Hydro Flow Qatar Pools</div>\n<div class=\"osts-client\">Cyath Contracting</div>\n<div class=\"osts-client\">M. Munif Al Otaibi</div>\n<div class=\"osts-client\">SKC Infra</div>\n<div class=\"osts-client\">Vijay Infra</div>\n<div class=\"osts-client\">Shiv Construction</div>\n<div class=\"osts-client\">MVB Constructions</div>\n<div class=\"osts-client\">GNA Construction</div>\n<div class=\"osts-client\">Alamdar Infrastructure</div>\n<div class=\"osts-client\">IGI Group</div>\n<div class=\"osts-client\">B.K Construction</div>\n</div>\n</div>\n</div>\n\n<section aria-label=\"Customer Reviews\" class=\"oscr-outer\">\n<div class=\"oscr-inner\">\n<div class=\"oscr-head\">\n<div class=\"oscr-label\"><div class=\"oscr-label-dot\"></div>Customer Reviews</div>\n<h2 class=\"oscr-h2\">Trusted by <em>10,000+ construction teams.</em></h2>\n<div class=\"oscr-aggregate\">\n<div class=\"oscr-agg-stars\">★★★★★</div>\n<div class=\"oscr-agg-score\">4.8 / 5</div>\n<div class=\"oscr-agg-sep\">—</div>\n<div class=\"oscr-agg-count\">Based on 500+ verified deployments</div>\n</div>\n</div>\n<div class=\"oscr-grid\">\n<div class=\"oscr-card\" itemscope=\"\" itemtype=\"https://schema.org/Review\">\n<div itemprop=\"itemReviewed\" itemscope=\"\" itemtype=\"https://schema.org/SoftwareApplication\"></div>\n<div itemprop=\"reviewRating\" itemscope=\"\" itemtype=\"https://schema.org/Rating\"></div>\n<div class=\"oscr-stars\">★★★★★</div>\n<p class=\"oscr-text\" itemprop=\"reviewBody\">“With SiteFlow, all the progress and cost details are visible in one place. It’s made client discussions much smoother because we’re now talking with actual site data instead of guesses.”</p>\n<div class=\"oscr-author\">\n<div class=\"oscr-avatar\">MK</div>\n<div itemprop=\"author\" itemscope=\"\" itemtype=\"https://schema.org/Person\">\n<p class=\"oscr-name\" itemprop=\"name\">Mr. Manish Kumar</p>\n<p class=\"oscr-company\">Reidius Infra, Jaipur · Design &amp; Build</p>\n</div>\n</div>\n</div>\n<div class=\"oscr-card\" itemscope=\"\" itemtype=\"https://schema.org/Review\">\n<div itemprop=\"itemReviewed\" itemscope=\"\" itemtype=\"https://schema.org/SoftwareApplication\"></div>\n<div itemprop=\"reviewRating\" itemscope=\"\" itemtype=\"https://schema.org/Rating\"></div>\n<div class=\"oscr-stars\">★★★★★</div>\n<p class=\"oscr-text\" itemprop=\"reviewBody\">“SiteFlow helped us monitor spending at activity level instead of discovering overruns later. It brought financial visibility closer to daily execution — which is exactly what we needed.”</p>\n<div class=\"oscr-author\">\n<div class=\"oscr-avatar\">HP</div>\n<div itemprop=\"author\" itemscope=\"\" itemtype=\"https://schema.org/Person\">\n<p class=\"oscr-name\" itemprop=\"name\">Mr. Hiren Patel</p>\n<p class=\"oscr-company\">DCC, Mumbai · Civil Construction</p>\n</div>\n</div>\n</div>\n<div class=\"oscr-card\" itemscope=\"\" itemtype=\"https://schema.org/Review\">\n<div itemprop=\"itemReviewed\" itemscope=\"\" itemtype=\"https://schema.org/SoftwareApplication\"></div>\n<div itemprop=\"reviewRating\" itemscope=\"\" itemtype=\"https://schema.org/Rating\"></div>\n<div class=\"oscr-stars\">★★★★★</div>\n<p class=\"oscr-text\" itemprop=\"reviewBody\">“We generate and share structured PDF reports directly from project data. It works reliably as a construction reporting software without confusion between site and office numbers.”</p>\n<div class=\"oscr-author\">\n<div class=\"oscr-avatar\">MT</div>\n<div itemprop=\"author\" itemscope=\"\" itemtype=\"https://schema.org/Person\">\n<p class=\"oscr-name\" itemprop=\"name\">Mr. Mohammad Founder</p>\n<p class=\"oscr-company\">Hydro Flow Qatar, Qatar · Interior &amp; Building</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n\n<div class=\"oscta-outer\">\n<div class=\"oscta-inner\">\n<div class=\"oscta-eyebrow\">\n<div class=\"oscta-ey-dot\"></div>\n      Ready to see it live\n