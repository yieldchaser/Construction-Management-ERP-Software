  "body": "\n\n<div class=\"ocsp-outer\">\n<div class=\"ocsp-inner\">\n<div class=\"ocsp-eyebrow\">\n<div class=\"ocsp-ey-dot\"></div>\n<span class=\"ocsp-ey-txt\">Transparent Pricing</span>\n</div>\n<h1 class=\"ocsp-h1\">SiteFlow ERP Pricing —<br/>Simple plans for <em class=\"ocsp-h1-em\">real site control.</em></h1>\n<p class=\"ocsp-sub\">No hidden charges. No per-project fees. One flat rate per user — covering everything your construction team needs from BOQ to billing.</p>\n<div class=\"ocsp-badges\">\n<div class=\"ocsp-badge\"><span class=\"ocsp-badge-check\">✓</span> No setup fee</div>\n<div class=\"ocsp-badge\"><span class=\"ocsp-badge-check\">✓</span> Free onboarding</div>\n<div class=\"ocsp-badge\"><span class=\"ocsp-badge-check\">✓</span> Cancel anytime</div>\n<div class=\"ocsp-badge\"><span class=\"ocsp-badge-check\">✓</span> Mobile + Web</div>\n</div>\n<div aria-label=\"Currency toggle\" class=\"ocsp-toggle-wrap\" role=\"group\">\n<span class=\"ocsp-toggle-lbl\" id=\"ocsp-lbl-in\">🇮🇳 Indian Pricing (₹)</span>\n<button aria-checked=\"false\" aria-label=\"Toggle pricing currency\" class=\"ocsp-toggle\" id=\"ocsp-toggle\" role=\"switch\"></button>\n<span class=\"ocsp-toggle-lbl dim\" id=\"ocsp-lbl-int\">🌎 International ($)</span>\n<span class=\"ocsp-save-tag\">Save 23% vs monthly</span>\n</div>\n<div class=\"ocsp-divider\"></div>\n</div>\n</div>\n\n\n<div class=\"ocsp2-outer\">\n<div class=\"ocsp2-wrap\">\n<div class=\"ocsp2-head ocsp2-anim\">\n<div class=\"ocsp2-eyebrow\"><span class=\"ocsp2-ey-dot\"></span>Plans &amp; Pricing</div>\n<div class=\"ocsp2-h2\">Choose the plan that fits <em class=\"ocsp2-h2-em\">your projects.</em></div>\n</div>\n<div class=\"ocsp2-grid\">\n<article class=\"ocsp2-card ocsp2-anim ocsp2-d1\" itemscope=\"\" itemtype=\"https://schema.org/Offer\">\n<div class=\"ocsp2-plan-name\">Business</div>\n<p class=\"ocsp2-plan-desc\">Designed for small construction businesses that need robust execution and daily site control.</p>\n<span class=\"ocsp2-price-orig\" id=\"ocsp2-b-orig\">₹15,600/User/Year</span>\n<span class=\"ocsp2-price-main\"><span id=\"ocsp2-b-price\" itemprop=\"price\">₹12,000</span><span class=\"ocsp2-gst-suffix\">+ GST</span></span>\n<span class=\"ocsp2-price-period\">/User/Year (Billed Annually)</span>\n<div class=\"ocsp2-min-tag\" id=\"ocsp2-b-min\"><span>🏷</span>Min. Billed ₹36,000/Year for 3 Users</div>\n<div class=\"ocsp2-divider\"></div>\n<p class=\"ocsp2-feat-head\">What’s included</p>\n<ul class=\"ocsp2-feat-list\">\n<li><span class=\"ocsp2-check\">✓</span>Payments &amp; Expenses</li>\n<li><span class=\"ocsp2-check\">✓</span>File Management</li>\n<li><span class=\"ocsp2-check\">✓</span>Labor Attendance &amp; Salary</li>\n<li><span class=\"ocsp2-check\">✓</span>CRM — Leads &amp; Quotation</li>\n<li><span class=\"ocsp2-check\">✓</span>Material Request &amp; Inventory</li>\n<li><span class=\"ocsp2-check\">✓</span>Task &amp; Sub-task Hierarchy</li>\n<li><span class=\"ocsp2-check\">✓</span>Issue / Snag List (To-do)</li>\n<li><span class=\"ocsp2-check\">✓</span>Subcon Work Order &amp; RA Billing</li>\n<li><span class=\"ocsp2-check\">✓</span>Multiple Roles &amp; Permissions</li>\n</ul>\n<div class=\"ocsp2-support\">\n<span class=\"ocsp2-support-lbl\">Support</span>\n<span class=\"ocsp2-support-note\">Complimentary with min 3 users</span>\n<div class=\"ocsp2-support-items\">\n<div class=\"ocsp2-support-item\"><span class=\"ocsp2-arrow\">→</span>WhatsApp &amp; Google Meet Support</div>\n<div class=\"ocsp2-support-item\"><span class=\"ocsp2-arrow\">→</span>Onboarding Support</div>\n</div>\n</div>\n<a class=\"ocsp2-cta ocsp2-cta-purple\" href=\"#ct-popup-48098\" itemprop=\"url\">Book a Free Demo</a>\n</article>\n<article class=\"ocsp2-card ocsp2-feat ocsp2-anim ocsp2-d2\" itemscope=\"\" itemtype=\"https://schema.org/Offer\">\n<div class=\"ocsp2-popular\">⭐ Most Popular</div>\n<div class=\"ocsp2-plan-name\">Business+</div>\n<p class=\"ocsp2-plan-desc\">Advanced tools for mid-sized to large construction companies managing complex operations.</p>\n<span class=\"ocsp2-price-orig\" id=\"ocsp2-bp-orig\">₹19,500/User/Year</span>\n<span class=\"ocsp2-price-main\"><span id=\"ocsp2-bp-price\" itemprop=\"price\">₹15,000</span><span class=\"ocsp2-gst-suffix\">+ GST</span></span>\n<span class=\"ocsp2-price-period\">/User/Year (Billed Annually)</span>\n<div class=\"ocsp2-min-tag\" id=\"ocsp2-bp-min\"><span>🏷</span>Min. Billed ₹45,000/Year for 3 Users</div>\n<div class=\"ocsp2-divider\"></div>\n<p class=\"ocsp2-inherit\"><span class=\"ocsp2-arrow\">→</span>Everything in Business, plus:</p>\n<p class=\"ocsp2-feat-head\">Advanced Features</p>\n<ul class=\"ocsp2-feat-list\">\n<li><span class=\"ocsp2-check\">✓</span>Design Management</li>\n<li><span class=\"ocsp2-check\">✓</span>Bill of Quantity (BOQ) &amp; RA Bills</li>\n<li><span class=\"ocsp2-check\">✓</span>Budget Control</li>\n<li><span class=\"ocsp2-check\">✓</span>Central Warehouse</li>\n<li><span class=\"ocsp2-check\">✓</span>RFQ (Request for Quotation)</li>\n<li><span class=\"ocsp2-check\">✓</span>Purchase Orders</li>\n<li><span class=\"ocsp2-check\">✓</span>Assets &amp; Tools</li>\n<li><span class=\"ocsp2-check\">✓</span>Equipment &amp; Machinery</li>\n<li><span class=\"ocsp2-check\">✓</span>Staff Payroll</li>\n<li><span class=\"ocsp2-check\">✓</span>Site Inspection</li>\n<li><span class=\"ocsp2-check\">✓</span>Multi-Level Approval</li>\n</ul>\n<div class=\"ocsp2-support\">\n<span class=\"ocsp2-support-lbl\">Support</span>\n<span class=\"ocsp2-support-note\">Complimentary with min 3 users</span>\n<div class=\"ocsp2-support-items\">\n<div class=\"ocsp2-support-item\"><span class=\"ocsp2-arrow\">→</span>Account Setup Support</div>\n<div class=\"ocsp2-support-item\"><span class=\"ocsp2-arrow\">→</span>Onboarding Support</div>\n</div>\n</div>\n<a class=\"ocsp2-cta ocsp2-cta-rose\" href=\"#ct-popup-48098\" itemprop=\"url\">Book a Free Demo</a>\n</article>\n<article class=\"ocsp2-card ocsp2-anim ocsp2-d3\" itemscope=\"\" itemtype=\"https://schema.org/Offer\">\n<div class=\"ocsp2-plan-name\">Enterprise</div>\n<p class=\"ocsp2-plan-desc\">Custom solutions for large-scale enterprises managing complex, multi-site operations.</p>\n<span class=\"ocsp2-price-main ocsp2-price-custom\" id=\"ocsp2-e-price\">Custom Pricing</span>\n<span class=\"ocsp2-price-sub-lg\"><span id=\"ocsp2-e-sub\">Starting from ₹12L+ / Year</span><span class=\"ocsp2-gst-suffix\">+ GST</span></span>\n<div class=\"ocsp2-min-tag\"><span>🏷</span>Unlimited Users</div>\n<div class=\"ocsp2-divider\"></div>\n<p class=\"ocsp2-inherit\"><span class=\"ocsp2-arrow\">→</span>Everything in Business+, plus:</p>\n<p class=\"ocsp2-feat-head\">Enterprise Features</p>\n<ul class=\"ocsp2-feat-list\">\n<li><span class=\"ocsp2-check\">✓</span>Unlimited Users</li>\n<li><span class=\"ocsp2-check\">✓</span>GPS Attendance</li>\n<li><span class=\"ocsp2-check\">✓</span>Custom Roles</li>\n<li><span class=\"ocsp2-check\">✓</span>Custom Dashboard</li>\n<li><span class=\"ocsp2-check\">✓</span>Accounting Integration (Zoho, Tally)</li>\n<li class=\"ocsp2-gap\"></li>\n<li><span class=\"ocsp2-star-icon\">★</span>Custom Requirements</li>\n<li><span class=\"ocsp2-star-icon\">★</span>Vendor Portal</li>\n<li><span class=\"ocsp2-star-icon\">★</span>Client Portal</li>\n<li><span class=\"ocsp2-star-icon\">★</span>White Labelled Solution</li>\n<li><span class=\"ocsp2-star-icon\">★</span>SAP Integration</li>\n</ul>\n<div class=\"ocsp2-support\">\n<span class=\"ocsp2-support-lbl\">Support</span>\n<span class=\"ocsp2-support-note\">Priority support</span>\n<div class=\"ocsp2-support-items\">\n<div class=\"ocsp2-support-item\"><span class=\"ocsp2-arrow\">→</span>WhatsApp &amp; Google Meet Support</div>\n<div class=\"ocsp2-support-item\"><span class=\"ocsp2-arrow\">→</span>Onboarding Support</div>\n</div>\n</div>\n<a class=\"ocsp2-cta ocsp2-cta-purple\" href=\"https://siteflow.com/contact/\">Talk to Sales</a>\n</article>\n</div>\n</div>\n</div>\n<div class=\"ocsp2-ao-outer\">\n<div class=\"ocsp2-ao-wrap\">\n<div class=\"ocsp2-ao-head ocsp2-anim\">\n<div class=\"ocsp2-ao-eyebrow\"><span class=\"ocsp2-ao-dot\"></span>Extend Your Plan</div>\n<div class=\"ocsp2-h2\">Power-up with <em class=\"ocsp2-h2-em\">add-ons.</em></div>\n</div>\n<div class=\"ocsp2-ao-grid\">\n<div class=\"ocsp2-ao-card ocsp2-anim ocsp2-d4\"><div class=\"ocsp2-ao-icon\">📍</div><span class=\"ocsp2-ao-name\">GPS + Facial Recognition</span><span class=\"ocsp2-ao-price\"><span id=\"ocsp2-ao1\">₹20,000/Year</span><span class=\"ocsp2-ao-gst\">+ GST</span></span><span class=\"ocsp2-ao-note\">Geo-tagged, fraud-proof attendance</span></div>\n<div class=\"ocsp2-ao-card ocsp2-anim ocsp2-d5\"><div class=\"ocsp2-ao-icon\">🏢</div><span class=\"ocsp2-ao-name\">Additional Company</span><span class=\"ocsp2-ao-price\"><span id=\"ocsp2-ao2\">₹20,000/Year</span><span class=\"ocsp2-ao-gst\">+ GST</span></span><span class=\"ocsp2-ao-note\">Run multiple entities on one account</span></div>\n<div class=\"ocsp2-ao-card ocsp2-anim ocsp2-d6\"><div class=\"ocsp2-ao-icon\">📊</div><span class=\"ocsp2-ao-name\">Tally Integration</span><span class=\"ocsp2-ao-price\"><span id=\"ocsp2-ao3\">₹20,000/Year</span><span class=\"ocsp2-ao-gst\">+ GST</span></span><span class=\"ocsp2-ao-note\" id=\"ocsp2-ao3n\">+ ₹5,000/Year maintenance</span></div>\n<div class=\"ocsp2-ao-card ocsp2-anim ocsp2-d4\"><div class=\"ocsp2-ao-icon\">📑</div><span class=\"ocsp2-ao-name\">Zoho Books Integration</span><span class=\"ocsp2-ao-price\"><span id=\"ocsp2-ao4\">₹20,000/Year</span><span class=\"ocsp2-ao-gst\">+ GST</span></span><span class=\"ocsp2-ao-note\" id=\"ocsp2-ao4n\">+ ₹5,000/Year maintenance</span></div>\n</div>\n</div>\n</div>\n\n\n<div class=\"ocsp3-outer\">\n<div class=\"ocsp3-wrap\">\n<div class=\"ocsp3-head ocsp3-anim\">\n<div class=\"ocsp3-badge\"><span class=\"ocsp3-badge-dot\"></span>Compare Plans</div>\n<div class=\"ocsp3-h2\">See exactly what’s <em class=\"ocsp3-h2-em\">included.</em></div>\n</div>\n<div class=\"ocsp3-table-wrap ocsp3-anim ocsp3-d1\">\n<table aria-label=\"Feature comparison across Business, Business+ and Enterprise plans\" class=\"ocsp3-table\" role=\"table\">\n<caption style=\"position:absolute!important;width:1px!important;height:1px!important;overflow:hidden!important;clip:rect(0,0,0,0)!important;white-space:nowrap!important;\">Feature comparison between Business, Business+ and Enterprise plans for SiteFlow Construction Management Software</caption>\n<thead>\n<tr class=\"ocsp3-thead-tr\">\n<th class=\"ocsp3-th\" scope=\"col\">Feature</th>\n<th class=\"ocsp3-th ocsp3-th-center\" scope=\"col\">Business</th>\n<th class=\"ocsp3-th ocsp3-th-gold\" scope=\"col\">Business+</th>\n<th class=\"ocsp3-th ocsp3-th-center\" scope=\"col\">Enterprise</th>\n</tr>\n</thead>\n<tbody>\n<tr class=\"ocsp3-group-row\"><td class=\"ocsp3-td\" colspan=\"4\">Pre-Construction</td></tr>\n<tr><td class=\"ocsp3-td\">CRM — Leads &amp; Quotation</td><td class=\"ocsp3-td\"><span class=\"ocsp3-tick\">✓</span></td><td class=\"ocsp3-td\"><span class=\"ocsp3-tick\">✓</span></td><td class=\"ocsp3-td\"><span class=\"ocsp3-tick\">✓</span></td></tr>\n<tr><td class=\"ocsp3-td\">Bill of Quantity (BOQ)</td><td class=\"ocsp3-td\"><span class=\"ocsp3-dash\">—</span></td><td class=\"ocsp3-td\"><span class=\"ocsp3-tick\">✓</span></td><td class=\"ocsp3-td\"><span class=\"ocsp3-tick\">✓</span></td></tr>\n<tr><td class=\"ocsp3-td\">Design Management</td><td class=\"ocsp3-td\"><span class=\"ocsp3-dash\">—</span></td><td class=\"ocsp3-td\"><span class=\"ocsp3-tick\">✓</span></td><td class=\"ocsp3-td\"><span class=\"ocsp3-tick\">✓</span></td></tr>\n<tr><td class=\"ocsp3-td\">Budget Control</td><td class=\"ocsp3-td\"><span class=\"ocsp3-dash\">—</span></td><td class=\"ocsp3-td\"><span class=\"ocsp3-tick\">✓</span></td><td class=\"ocsp3-td\"><span class=\"ocsp3-tick\">✓</span></td></tr>\n<tr class=\"ocsp3-group-row\"><td class=\"ocsp3-td\" colspan=\"4\">Project Execution</td></tr>\n<tr><t