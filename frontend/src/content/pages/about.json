  "body": "<style>\n/* ── GAP FIX ── */\n.wp-block-html:has(.abh-outer) { margin-block-start:0!important;margin-top:0!important;padding-top:0!important; }\n.abh-outer { margin-top:calc(-1 * var(--theme-content-spacing,40px))!important; }\n/* ── OUTER ── */\n.abh-outer {\n  width:100vw!important;max-width:100vw!important;\n  margin-left:calc(-50vw + 50%)!important;\n  position:relative!important;overflow-x:hidden!important;\n  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif!important;\n  /* COLOR: rose-tinted light base — #fff5f7 */\n  background-color:#fff5f7!important;\n  background-image:\n    repeating-linear-gradient(-55deg,transparent,transparent 28px,rgba(211,13,80,0.03) 28px,rgba(211,13,80,0.03) 29px),\n    radial-gradient(circle,rgba(211,13,80,0.08) 1.2px,transparent 1.2px),\n    radial-gradient(ellipse 65% 55% at 0% 0%,rgba(211,13,80,0.10) 0%,transparent 65%),\n    radial-gradient(ellipse 55% 45% at 100% 0%,rgba(211,13,80,0.06) 0%,transparent 60%),\n    linear-gradient(160deg,#ffffff 0%,#fff0f3 50%,#fff5f7 100%)!important;\n  background-size:auto,28px 28px,100% 100%,100% 100%,100% 100%!important;\n  padding:clamp(56px,8vw,96px) 0 clamp(48px,7vw,80px)!important;\n  border-bottom:1px solid rgba(211,13,80,0.12)!important;\n}\n.abh-outer * { box-sizing:border-box!important; }\n/* ── WRAP ── */\n.abh-wrap {\n  max-width:1200px!important;margin:0 auto!important;\n  padding:0 clamp(20px,4vw,40px)!important;\n  position:relative!important;z-index:1!important;\n}\n/* ── GRID ── */\n.abh-grid {\n  display:grid!important;\n  grid-template-columns:1fr clamp(340px,38%,440px)!important;\n  gap:clamp(40px,5vw,64px)!important;\n  align-items:center!important;\n}\n/* ── SCROLL REVEAL — will-change NOT in CSS; set in JS at observe time ── */\n.abh-rev { opacity:0!important;transform:translateY(24px)!important;transition:opacity 0.6s ease,transform 0.6s ease!important; }\n.abh-rev.abh-in { opacity:1!important;transform:none!important; }\n.abh-rev-r { opacity:0!important;transform:translateX(24px)!important;transition:opacity 0.6s ease,transform 0.6s ease!important; }\n.abh-rev-r.abh-in { opacity:1!important;transform:none!important; }\n.abh-d1{transition-delay:0.07s!important}.abh-d2{transition-delay:0.14s!important}\n.abh-d3{transition-delay:0.21s!important}.abh-d4{transition-delay:0.28s!important}\n/* ── LEFT TEXT ── */\n.abh-left { display:flex!important;flex-direction:column!important;gap:clamp(18px,2.5vw,24px)!important; }\n/* Founded chip — rose */\n.abh-founded {\n  display:inline-flex!important;align-items:center!important;gap:6px!important;\n  flex-wrap:wrap!important;\n  background:rgba(211,13,80,0.07)!important;border:1px solid rgba(211,13,80,0.20)!important;\n  border-radius:100px!important;padding:6px 16px!important;\n  width:fit-content!important;max-width:100%!important;\n}\n/* INFINITE blink — will-change:opacity CORRECT, kept */\n.abh-founded-dot {\n  width:7px!important;height:7px!important;border-radius:50%!important;\n  background:#d30d50!important;flex-shrink:0!important;\n  animation:abh-blink 2s ease-in-out infinite!important;will-change:opacity!important;\n}\n@keyframes abh-blink { 0%,100%{opacity:1} 50%{opacity:0.3} }\n.abh-founded-txt { font-size:clamp(11px,1.3vw,13px)!important;font-weight:600!important;color:#a50c3c!important;letter-spacing:0.03em!important; }\n.abh-founded-sep { color:rgba(211,13,80,0.35)!important;font-weight:400!important; }\n.abh-founded-em { color:#a50c3c!important;font-style:normal!important;font-weight:700!important; }\n/* H1 — rose accent */\n.abh-h1 {\n  font-size:clamp(2rem,5vw,3.8rem)!important;font-weight:800!important;\n  line-height:1.08!important;letter-spacing:-0.03em!important;color:#0f0a1e!important;margin:0!important;\n}\n.abh-h1-accent { color:#d30d50!important;font-style:italic!important; }\n/* Sub */\n.abh-sub { font-size:clamp(14px,1.7vw,17px)!important;color:#4b5563!important;line-height:1.72!important;margin:0!important;max-width:500px!important; }\n.abh-sub strong { color:#0f0a1e!important;font-weight:700!important; }\n/* Buttons — primary rose gradient */\n.abh-btns { display:flex!important;gap:clamp(8px,1.5vw,12px)!important;flex-wrap:wrap!important; }\n.abh-btn-primary {\n  display:inline-flex!important;align-items:center!important;gap:6px!important;\n  font-size:clamp(13px,1.5vw,15px)!important;font-weight:700!important;\n  background:linear-gradient(135deg,#f43f6e,#d30d50)!important;\n  color:#ffffff!important;\n  padding:clamp(10px,1.4vw,13px) clamp(20px,2.5vw,26px)!important;\n  border-radius:9px!important;text-decoration:none!important;border:none!important;\n  cursor:pointer!important;box-shadow:0 4px 16px rgba(211,13,80,0.30)!important;\n  transition:transform 0.18s ease!important;\n}\n.abh-btn-primary:hover { transform:translateY(-2px)!important;color:#ffffff!important;text-decoration:none!important; }\n.abh-btn-outline {\n  display:inline-flex!important;align-items:center!important;gap:6px!important;\n  font-size:clamp(13px,1.5vw,15px)!important;font-weight:600!important;\n  background:#fff!important;color:#0f0a1e!important;\n  border:1.5px solid rgba(15,10,30,0.15)!important;\n  padding:clamp(10px,1.4vw,13px) clamp(20px,2.5vw,26px)!important;\n  border-radius:9px!important;text-decoration:none!important;cursor:pointer!important;\n  transition:transform 0.18s ease!important;\n}\n.abh-btn-outline:hover { transform:translateY(-2px)!important;text-decoration:none!important; }\n/* Award chips — rose */\n.abh-awards { display:flex!important;gap:8px!important;flex-wrap:wrap!important; }\n.abh-award {\n  display:inline-flex!important;align-items:center!important;gap:5px!important;\n  font-size:clamp(11px,1.2vw,13px)!important;font-weight:700!important;\n  color:#a50c3c!important;\n  background:rgba(211,13,80,0.07)!important;\n  border:1px solid rgba(211,13,80,0.18)!important;\n  border-radius:4px!important;padding:4px 10px!important;\n}\n/* ── RIGHT TILES ── */\n.abh-right { display:flex!important;flex-direction:column!important;gap:12px!important; }\n.abh-tiles-grid { display:grid!important;grid-template-columns:1fr 1fr!important;gap:12px!important; }\n/* Light tiles — rose borders and shadow */\n.abh-tile {\n  background:#fff!important;border:1.5px solid rgba(211,13,80,0.12)!important;\n  border-radius:14px!important;padding:clamp(16px,2.5vw,20px) clamp(14px,2vw,18px)!important;\n  box-shadow:0 4px 20px rgba(211,13,80,0.07)!important;\n}\n/* Dark tiles — deep rose background, 20% purple preserved in num color */\n.abh-tile-dark {\n  background:linear-gradient(135deg,#1a0510,#3d0520)!important;\n  border:1px solid rgba(211,13,80,0.25)!important;\n  border-radius:14px!important;padding:clamp(16px,2.5vw,20px) clamp(14px,2vw,18px)!important;\n  box-shadow:0 4px 20px rgba(211,13,80,0.15)!important;\n}\n/* Stat numbers — rose for light, soft pink for dark (20% purple tint via #fda4b8) */\n.abh-tile-num { font-size:clamp(1.4rem,3vw,1.9rem)!important;font-weight:800!important;line-height:1!important;margin-bottom:4px!important;color:#d30d50!important;letter-spacing:-0.03em!important; }\n.abh-tile-num em { font-style:normal!important; }\n.abh-tile-num-dark { font-size:clamp(1.4rem,3vw,1.9rem)!important;font-weight:800!important;line-height:1!important;margin-bottom:4px!important;color:#fda4b8!important;letter-spacing:-0.03em!important; }\n.abh-tile-lbl { font-size:clamp(10px,1.2vw,12px)!important;color:#6b7280!important;font-weight:500!important;line-height:1.4!important; }\n.abh-tile-lbl-dark { font-size:clamp(10px,1.2vw,12px)!important;color:rgba(255,255,255,0.50)!important;font-weight:500!important;line-height:1.4!important; }\n/* Quote card — rose border-left and label */\n.abh-quote-card {\n  background:#fff!important;border:1.5px solid rgba(211,13,80,0.10)!important;\n  border-radius:14px!important;padding:clamp(14px,2vw,18px) clamp(16px,2.5vw,20px)!important;\n  border-left:4px solid #d30d50!important;box-shadow:0 4px 16px rgba(211,13,80,0.07)!important;\n}\n.abh-quote-label { font-size:clamp(9px,1.1vw,11px)!important;font-weight:700!important;text-transform:uppercase!important;letter-spacing:0.09em!important;color:#d30d50!important;margin-bottom:8px!important; }\n.abh-quote-text { font-size:clamp(12px,1.4vw,14px)!important;font-style:italic!important;color:#374151!important;line-height:1.65!important;margin:0 0 8px!important; }\n.abh-quote-attr { font-size:clamp(10px,1.1vw,12px)!important;color:#9ca3af!important; }\n/* ── MOBILE ── */\n@media (max-width:900px) {\n  .abh-grid { grid-template-columns:1fr!important;gap:clamp(32px,5vw,48px)!important; }\n  .abh-left { order:1!important; }\n  .abh-right { order:2!important; }\n  .abh-sub { max-width:100%!important; }\n}\n@media (max-width:480px) {\n  .abh-btns { flex-direction:column!important; }\n  .abh-btn-primary,.abh-btn-outline { justify-content:center!important; }\n}\n</style>\n<div class=\"abh-outer\">\n<div class=\"abh-wrap\">\n<div class=\"abh-grid\">\n<div class=\"abh-\">\n<div class=\"abh-founded abh-rev\">\n<div class=\"abh-founded-dot\"></div>\n<span class=\"abh-founded-txt\">Founded <span class=\"abh-founded-em\">2021</span></span>\n<span class=\"abh-founded-sep\">·</span>\n<span class=\"abh-founded-txt\"></span>\n<span class=\"abh-founded-sep\">·</span>\n<span class=\"abh-founded-txt\"><span class=\"abh-founded-em\">SiteFlow</span></span>\n</div>\n<div class=\"abh-h1 abh-rev\">\n          Supercharge Your<br/>\n<span class=\"abh-h1-accent\">Construction Business.</span>\n</div>\n<div class=\"abh-sub abh-rev\">\n          We are <strong>SiteFlow</strong> — a construction ERP built specifically for Indian contractors, builders, and EPC firms. Not a generic ERP with a construction module. <strong>A system designed from real project sites</strong>, for the way India builds.\n        </div>\n<div class=\"abh-btns abh-rev\">\n<a class=\"abh-btn-primary\" href=\"#ct-popup-48098\">Book a Free Demo →</a>\n<a class=\"abh-btn-outline\" href=\"https://siteflow.com/customers/\">See Client Stories</a>\n</div>\n<div class=\"abh-awards abh-rev\">\n<span class=\"abh-award\">🏆 4.8★ Rated by Site Teams</span>\n<span class=\"abh-award\">🌎 India &amp; Middle East</span>\n</div>\n</div>\n<div class=\"abh- abh-rev-r\">\n<div class=\"abh-tiles-grid\">\n<div class=\"abh-tile\">\n<div class=\"abh-tile-num\">500<em>+</em></div>\n<div class=\"abh-tile-lbl\">Active Clients<br/>India &amp; Middle East</div>\n</div>\n<div class=\"abh-tile\">\n<div class=\"abh-tile-num\">₹500<em>Cr+</em></div>\n<div class=\"abh-tile-lbl\">Construction Value<br/>Managed</div>\n</div>\n<div class=\"abh-tile-dark\">\n<div class=\"abh-tile-num-dark\">98%</div>\n<div class=\"abh-tile-lbl-dark\">Client Renewal<br/>Rate</div>\n</div>\n<div class=\"abh-tile-dark\">\n<div class=\"abh-tile-num-dark\">&lt;1 day</div>\n<div class=\"abh-tile-lbl-dark\">Average Time<br/>to Go Live</div>\n</div>\n</div>\n<div class=\"abh-quote-card\">\n<div class=\"abh-quote-label\">Trusted by contractors since 2021</div>\n<div class=\"abh-quote-text\">“We used to lose 3–4 days every month reconciling site records with Tally. SiteFlow cut that to an afternoon.”</div>\n<div class=\"abh-quote-attr\">— Project Manager, EPC Company, Ahmedabad</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"abs-outer\">\n<div class=\"abs-wrap\">\n<div class=\"abs--grid\">\n<div class=\"abs- abs-rev-l\">\n<div class=\"abs-badge\"><span class=\"abs-badge-dot\"></span>Our </div>\n<div class=\"abs-year\">2021</div>\n<div class=\"abs--h2\">How SiteFlow Construction ERP Was Founded</div>\n<div class=\"abs--p\">Founded in India. Built for contractors everywhere.</div>\n</div>\n<div class=\"abs-rev\">\n<div class=\"abs-body-p\">SiteFlow (legally <strong>SiteFlow ERP</strong>) is a <strong>construction ERP software company</strong> founded in <strong>2021</strong>. We observed that Indian construction contractors were managing crore-value projects on WhatsApp groups and paper registers — not from lack of discipline, but from lack of tools built for how they actually work.</div>\n<div class=\"abs-body-p\">Every construction ERP they tried was built for manufacturing or a Western market. The language didn’t match. The workflows didn’t match. The pricing assumed an IT department — which no contractor has. So most gave up and went back to Excel.</div>\n<div class=\"abs-callout\">\n<div class=\"abs-callout-p\">“The problem wasn’t that contractors lacked discipline. The problem was that <strong>the tools available were designed for someone else.</strong> We set out to build the construction management software that should have existed.”</div>\n</div>\n<div class=\"abs-body-p\">We spent months on actual project sites before writing a line of code. We watched <a href=\"https://siteflow.com/products/best-material-management-software/\">material management</a> happen on paper. We watched <a href=\"https://siteflow.com/products/construction-labour-management-software/\">labour attendance</a> tracked in registers that got lost. We saw billing disputes happen because there was no single source of truth for <a href=\"https://siteflow.com/vendor-billing-software-for-construction/\">subcontractor billing</a>.</div>\n<div class=\"abs-body-p\">Today, SiteFlow is trusted by <strong>500+ construction companies</strong> across India and the Middle East. We are headquartered in <strong>Delhi, India</strong> and serve clients in UAE, Qatar, and Saudi Arabia.</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"abs--outer\">\n<div class=\"abs-wrap\">\n<div class=\"abs--grid\">\n<div class=\"abs-fact-card abs-rev abs-d1\"><div class=\"abs-fact-lbl\">Founded</div><div class=\"abs-fact-val\">2021</div><div class=\"abs-fact-sub\">India</div></div>\n<div class=\"abs-fact-card abs-rev abs-d2\"><div class=\"abs-fact-lbl\">Legal Name</div><div class=\"abs-fact-val\" style=\"font-size:clamp(12px,1.4vw,15px)!important\">SiteFlow</div><div class=\"abs-fact-sub\">Registered in India</div></div>\n<div class=\"abs-fact-card abs-rev abs-d3\"><div class=\"abs-fact-lbl\">Category</div><div class=\"abs-fact-val\" style=\"font-size:clamp(12px,1.4vw,14px)!important\">Construction ERP &amp; PM Software</div><div class=\"abs-fact-sub\">SaaS · B2B · Mobile-First</div></div>\n<div class=\"abs-fact-card abs-rev abs-d4\"><div class=\"abs-fact-lbl\">Markets</div><div class=\"abs-fact-val\">India &amp; Middle East</div><div class=\"abs-fact-sub\">UAE · Qatar · Saudi Arabia</div></div>\n<div class=\"abs-fact-card abs-rev abs-d5\"><div class=\"abs-fact-lbl\">Active Clients</div><div class=\"abs-fact-val\">500<span style=\"color:#d30d50!important;\">+</span></div><div class=\"abs-fact-sub\">Contractors, Builders, EPC Firms</div></div>\n<div class=\"abs-fact-card abs-rev abs-d6\"><div class=\"abs-fact-lbl\">Integrations</div><div class=\"abs-fact-val\" style=\"font-size:clamp(12px,1.4vw,15px)!important\">Tally ERP &amp; Zoho Books</div><div class=\"abs-fact-sub\">GPS · WhatsApp API · Zoho CRM</div></div>\n</div>\n</div>\n</div>\n  ============================================================\n  "
