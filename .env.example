# ==============================================================================
# SiteFlow Core Configuration Variables Example
# Copy this file to '.env' and adjust values for local development or production.
# ==============================================================================

# --- DATABASE CONFIGURATION ---
# Local SQLite fallback URL for development and testing:
# DATABASE_URL=sqlite:///./test.db
# PostgreSQL / Supabase connection URL (Production):
DATABASE_URL=postgresql://postgres.yourprojectref:yourpassword@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# --- JWT AUTHENTICATION CONFIGURATION ---
# Generate a secure random string using `openssl rand -hex 32`
SECRET_KEY=supersecretjwtkeyforlocaldevelopmentsiteflowapp2026!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- FRONTEND ENVIRONMENT VARIABLES (Next.js) ---
# Set the backend URL for API communications from the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
